---
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';
import RegisterForm from '../../islands/RegisterForm.tsx';
---

<Layout title="Daftar - BookVerse">
  <Navbar />
  <main class="flex-1 flex items-center justify-center bg-bg-canvas py-12">
    <div class="w-full max-w-md px-4">
      <div class="bg-surface-card rounded-lg shadow-level2 border border-border p-8">
        <div class="text-center mb-8">
          <h1 class="font-display text-2xl font-bold text-fg">Daftar BookVerse</h1>
          <p class="mt-2 text-fg-secondary">Buat akun baru</p>
        </div>
        <RegisterForm client:load />
        <p class="mt-6 text-center text-sm text-fg-secondary">
          Sudah punya akun? <a href="/auth/login" class="text-primary hover:text-primary-hover font-medium">Masuk</a>
        </p>
      </div>
    </div>
  </main>
  <Footer />
</Layout>
